# ─────────────────────────────────────────────────────────────────────────────
# AI Content OS — Environment Variables
# Kopiere: cp .env.example .env.local   (NIEMALS .env.local in Git committen)
# ─────────────────────────────────────────────────────────────────────────────

# App
DEMO_MODE="false"

# Datenbank
DATABASE_URL="file:./dev.db"

# ── YouTube Upload + Analytics (PFLICHT für echten Upload) ────────────────────
# Setup: node scripts/get-youtube-token.js
# Konsole: https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── TikTok (optional) ─────────────────────────────────────────────────────────
# https://developers.tiktok.com → Scopes: video.publish, video.list
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ── Instagram (manuell — kein Auto-Upload möglich ohne App Review) ────────────
# META_APP_ID=
# META_APP_SECRET=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ── Stock Assets (optional — Mixkit-Fallback ohne Keys) ──────────────────────
# Pexels: https://www.pexels.com/api/
# Pixabay: https://pixabay.com/api/docs/
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ── Video Engine (optional — FFmpeg läuft lokal ohne Key) ────────────────────
# Shotstack: https://shotstack.io (Cloud-Fallback)
SHOTSTACK_API_KEY=
SHOTSTACK_ENV="stage"

# Freesound (Hintergrundmusik): https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=

# Docker Build
# DOCKER_BUILD="true"
